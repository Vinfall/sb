{
    "version": "139.0.7258.143",
    "description": "Chromium fork based on Bromite with built-in support for ad blocking and an eye for privacy",
    "homepage": "https://github.com/uazo/cromite",
    "license": {
        "identifier": "GPL-3.0-only",
        "url": "https://github.com/uazo/cromite/blob/master/LICENSE"
    },
    "architecture": {
        "64bit": {
            "url": "https://github.com/uazo/cromite/releases/download/v139.0.7258.143-8b0ce0bcfdca08fb2ebb937d31c80d68488343f8/chrome-win.zip",
            "hash": "fd290a704439ce5e1803d74c23366dd5e8e2e65daedbb898822f92623353f8d4"
        }
    },
    "extract_dir": "chrome-win",
    "env_set": {
        "CHROME_EXECUTABLE": "$dir\\chrome.exe"
    },
    "bin": [
        [
            "chrome.exe",
            "cromite",
            "--incognito"
        ]
    ],
    "shortcuts": [
        [
            "chrome.exe",
            "Cromite",
            "--incognito"
        ]
    ],
    "notes": "extras/cromite is recommended unless you hate persist 'User Data'.",
    "checkver": {
        "github": "https://github.com/uazo/cromite",
        "regex": "/releases/tag/v([\\d.]+)-(?<sha>[0-9a-f]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/uazo/cromite/releases/download/v$version-$matchSha/chrome-win.zip"
            }
        }
    }
}
